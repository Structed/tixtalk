# =============================================================================
# Pretix + Pretalx Configuration
# =============================================================================
# Copy this file to .env and fill in the values:
#   cp .env.example .env
#
# The deploy.sh script will generate secrets automatically if left blank.
# =============================================================================

# Your domain name (required)
# DNS must point your hostnames to this server's IP (default: tickets.<DOMAIN> and talks.<DOMAIN>,
# or use TICKETS_HOST/TALKS_HOST below for custom hostnames)
DOMAIN=yourdomain.com

# Environment: "prod" or "dev" (controls backup scheduling, etc.)
ENVIRONMENT=prod

# --- Host overrides (optional — auto-computed from DOMAIN if blank) ---
# Subdomain prefix for non-production environments (e.g., "dev-" → dev-tickets.yourdomain.com)
SUBDOMAIN_PREFIX=
# Full hostnames for ticketing and talks (auto-computed as {SUBDOMAIN_PREFIX}{tickets|talks}.{DOMAIN} if blank)
TICKETS_HOST=
TALKS_HOST=

# --- Cloudflare (optional — automates DNS record creation) ---
# Create an API token at: https://dash.cloudflare.com/profile/api-tokens
# Required permissions: Zone > DNS > Edit
# Zone ID: found on your domain's Overview page in Cloudflare dashboard
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=
# Use Cloudflare DNS challenge for TLS (enables orange-cloud proxy).
# Set to "false" for standard HTTP challenge (requires port 80 open, Cloudflare proxy off).
CLOUDFLARE_DNS_CHALLENGE=true

# --- Database ---
DB_USER=tixtalk
DB_PASSWORD=

# --- Pretix (ticketing) ---
PRETIX_SECRET_KEY=
PRETIX_IMAGE_TAG=stable

# --- Pretalx (call for papers) ---
PRETALX_SECRET_KEY=
PRETALX_IMAGE_TAG=latest

# --- Email (required for ticket confirmations and CfP notifications) ---
MAIL_FROM=noreply@yourdomain.com
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
